{
  "name": "@folotoy/folotoy-openclaw-plugin",
  "version": "0.2.0",
  "description": "Empower your FoloToy with OpenClaw AI capabilities.",
  "keywords": [
    "folotoy",
    "openclaw"
  ],
  "homepage": "https://github.com/FoloToy/folotoy-openclaw-plugin#readme",
  "bugs": {
    "url": "https://github.com/FoloToy/folotoy-openclaw-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FoloToy/folotoy-openclaw-plugin.git"
  },
  "license": "MIT",
  "author": "Larry Wang",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "mqtt": "^5.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "openclaw": "^2026.3.8",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "channel": {
      "id": "folotoy",
      "label": "FoloToy",
      "selectionLabel": "FoloToy",
      "docsPath": "/channels/folotoy",
      "blurb": "Empower your FoloToy with OpenClaw AI capabilities."
    }
  }
}
